# ── SPA Routing ───────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── Block .git directory explicitly ──
  RewriteRule ^\.git(/.*)?$ - [F,L]

  # ── Block all hidden files and directories (except .well-known) ──
  RewriteRule "(^|/)\.(?!well-known|htaccess)" - [F,L]

  # ── Block source/config files from web access ──
  RewriteRule \.(ts|tsx|jsx|md|lock|local\.php|gitignore|editorconfig)$ - [F,L]
  RewriteRule ^(package\.json|package-lock\.json|tsconfig.*|vite\.config.*|tailwind\.config.*|postcss\.config.*|components\.json|eslint.*)$ - [F,L]
  RewriteRule ^(node_modules|src|\.vscode|\.idea)(/.*)?$ - [F,L]

  # ── SPA fallback ──
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# ── Compression ───────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml text/xml
</IfModule>

# ── Cache Control ─────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Hashed assets — immutable long cache
  <FilesMatch "\.(?:css|js|mjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images & fonts — long cache
  <FilesMatch "\.(?:png|jpg|jpeg|gif|svg|webp|ico|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML & manifest — always revalidate
  <FilesMatch "^(?:index\.html|site\.webmanifest|robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # ── Hide server technology ──
  Header unset X-Powered-By
  Header unset Server
  Header always unset X-Powered-By
  Header always unset Server

  # ── Security Headers ──
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header set X-XSS-Protection "0"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

  # Vary for compressed content
  Header append Vary Accept-Encoding
</IfModule>

# ── Block access to sensitive files ──────────────────────────────────────────
<FilesMatch "\.(local\.php|log|json|sql|bak|env|ini|conf|yaml|yml|toml|sh|py|rb)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# ── Allow specific JSON files needed by the browser ──────────────────────────
<FilesMatch "^(site\.webmanifest)$">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
</FilesMatch>

# ── Hide PHP version ─────────────────────────────────────────────────────────
<IfModule mod_php.c>
  php_flag expose_php Off
  php_flag display_errors Off
  php_flag display_startup_errors Off
  php_value error_reporting 0
</IfModule>
<IfModule mod_php8.c>
  php_flag expose_php Off
  php_flag display_errors Off
  php_flag display_startup_errors Off
  php_value error_reporting 0
</IfModule>

# ── Disable server signature ─────────────────────────────────────────────────
ServerSignature Off

# ── MIME Types ────────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
</IfModule>

# ── ETags (disable inode-based) ───────────────────────────────────────────────
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# ── Custom error pages (prevent default Apache pages from leaking info) ──────
ErrorDocument 403 "Forbidden"
ErrorDocument 404 "Not Found"
ErrorDocument 500 "Server Error"
