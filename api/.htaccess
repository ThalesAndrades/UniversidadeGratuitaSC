# ── API Security ──────────────────────────────────────────────────────────────

# Block direct access to config, SQL, and support files
<FilesMatch "\.(local\.php|sql|example|md|json|log|bak|sh)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Block security.php from direct access (must be included, not requested)
<Files "security.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</Files>

# Block access to hidden files and directories
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule "(^|/)\.(?!htaccess)" - [F]
</IfModule>

# Disable directory browsing
Options -Indexes

# Hide PHP and server identity
<IfModule mod_headers.c>
  Header unset X-Powered-By
  Header unset Server
  Header always unset X-Powered-By
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

# Suppress PHP info
<IfModule mod_php.c>
  php_flag expose_php Off
  php_flag display_errors Off
</IfModule>
<IfModule mod_php8.c>
  php_flag expose_php Off
  php_flag display_errors Off
</IfModule>
